{
  "name": "resume-matcher",
  "version": "1.0.0",
  "description": "A web application for matching resumes with job descriptions",
  "main": "index.html",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "static": "node server.mjs",
    "build": "node ./scripts/validate-project.mjs",
    "lint": "node ./scripts/validate-project.mjs",
    "test": "node ./scripts/smoke-static-site.mjs",
    "ci:validate": "npm run lint && npm run test",
    "docker:build": "docker build --target production -t resume-matcher .",
    "docker:run": "docker run -p 8080:8080 resume-matcher",
    "docker:compose": "docker-compose up"
  },
  "keywords": [
    "resume",
    "matcher",
    "ats",
    "recruitment",
    "job-matching"
  ],
  "author": "Resume Matcher Team",
  "license": "MIT",
  "devDependencies": {
    "serve": "^14.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammadhammad2005/MatchlyPro.git"
  }
}
