# Docker ignore file for Matchly Resume Matcher

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor
.vscode
.idea
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git
.gitignore
.gitattributes

# Build artifacts
dist
build
.coverage
.nyc_output

# Logs
logs
*.log

# Temporary files
tmp
temp

# Documentation files (except README)
*.md
!README.md

# Test files
__tests__
__mocks__
coverage
*.test.js
*.spec.js

# Docker compose override
docker-compose.override.yml

# CI/CD artifacts
.github/workflows/*.txt
.github/workflows/*.log

# Security scan reports
*.sarif
trivy-report.json
grype-report.json